#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
===================================
DSA-CLI — Daily Stock Analysis CLI for OpenClaw Integration
===================================

A command-line interface for stock analysis, optimized for OpenClaw integration.
Designed for local execution on the same machine as OpenClaw.

Usage:
    dsa-cli analyze <stock_code>        # Full AI analysis
    dsa-cli quote <stock_code>          # Real-time quote
    dsa-cli trend <stock_code>          # Technical trend analysis
    dsa-cli news <stock_code>           # Search stock news
    dsa-cli batch <codes>               # Batch analysis (comma-separated)
    dsa-cli ma <stock_code>             # Moving average analysis
    dsa-cli pattern <stock_code>        # K-line pattern recognition
    dsa-cli volume <stock_code>         # Volume-price analysis
    dsa-cli levels <stock_code>         # Support/resistance levels

Options:
    --json          Output as JSON (for OpenClaw parsing)
    --brief         Brief output (reduced token consumption)
    --days N        Historical days for analysis (default: 60)
    --help          Show help message
"""

import argparse
import json
import logging
import sys
import os
from datetime import datetime
from typing import Any, Dict, List, Optional

# Setup environment before importing src modules
def setup_env():
    """Setup environment variables and Python path."""
    # Add project root to Python path
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)
    
    # Load .env if exists
    env_file = os.path.join(script_dir, ".env")
    if os.path.exists(env_file):
        from dotenv import load_dotenv
        load_dotenv(env_file)

setup_env()

# Now import project modules
from data_provider.base import canonical_stock_code
from src.logging_config import setup_logging

logger = logging.getLogger(__name__)


# ============================================================
# Output Formatters
# ============================================================

def format_json(data: Dict[str, Any]) -> str:
    """Format output as JSON."""
    return json.dumps(data, ensure_ascii=False, indent=2, default=str)


def format_brief(data: Dict[str, Any], command: str) -> str:
    """Format brief output for reduced token consumption."""
    if "error" in data:
        return f"Error: {data['error']}"
    
    lines = []
    
    if command == "quote":
        lines.append(f"{data.get('name', data.get('code', 'N/A'))} ({data.get('code', 'N/A')})")
        lines.append(f"Price: {data.get('price', 'N/A')} | Change: {data.get('change_pct', 'N/A')}%")
        lines.append(f"Volume: {data.get('volume', 'N/A')} | Turnover: {data.get('turnover_rate', 'N/A')}%")
    
    elif command == "trend":
        lines.append(f"{data.get('code', 'N/A')} Trend: {data.get('trend_status', 'N/A')}")
        lines.append(f"MA Alignment: {data.get('ma_alignment', 'N/A')}")
        lines.append(f"Signal: {data.get('buy_signal', 'N/A')} (Score: {data.get('signal_score', 'N/A')})")
        lines.append(f"MACD: {data.get('macd_signal', 'N/A')} | RSI: {data.get('rsi_status', 'N/A')}")
    
    elif command == "ma":
        lines.append(f"{data.get('code', 'N/A')} @ {data.get('current_price', 'N/A')}")
        lines.append(f"Alignment: {data.get('ma_alignment', 'N/A')}")
        ma_data = data.get("ma", {})
        for key in ["ma5", "ma10", "ma20", "ma60"]:
            if key in ma_data and ma_data[key]:
                v = ma_data[key]
                lines.append(f"  {key.upper()}: {v.get('value', 'N/A')} (bias: {v.get('bias_pct', 'N/A')}%)")
    
    elif command == "news":
        news_list = data.get("news", [])
        lines.append(f"Found {len(news_list)} news for {data.get('code', 'N/A')}")
        for i, item in enumerate(news_list[:5], 1):
            lines.append(f"{i}. {item.get('title', 'N/A')}")
            lines.append(f"   {item.get('source', 'N/A')} - {item.get('published_date', 'N/A')}")
    
    elif command == "pattern":
        patterns = data.get("patterns", [])
        lines.append(f"{data.get('code', 'N/A')} @ {data.get('current_price', 'N/A')}")
        if patterns:
            lines.append(f"Patterns ({len(patterns)}):")
            for p in patterns[:5]:
                lines.append(f"  - {p.get('pattern', 'N/A')}: {p.get('desc', 'N/A')}")
        else:
            lines.append("No significant patterns detected")
    
    elif command == "volume":
        lines.append(f"{data.get('code', 'N/A')} Volume Analysis")
        lines.append(f"Vol Ratio 5d: {data.get('volume_ratio_vs_5d', 'N/A')}x")
        lines.append(f"Trend: {data.get('volume_trend', 'N/A')}")
        lines.append(f"Pattern: {data.get('pattern', 'N/A')}")
    
    elif command == "levels":
        levels = data.get("levels", [])
        lines.append(f"{data.get('code', 'N/A')} Key Levels")
        for lv in levels[:6]:
            lines.append(f"  {lv.get('price', 'N/A')}: {lv.get('type', 'N/A')} ({lv.get('strength', 'N/A')})")
    
    elif command == "analyze":
        # Full analysis brief output
        report = data.get("report", {})
        summary = report.get("summary", {})
        strategy = report.get("strategy", {})
        
        lines.append(f"=== {data.get('stock_name', data.get('stock_code', 'N/A'))} ({data.get('stock_code', 'N/A')}) ===")
        lines.append(f"Score: {summary.get('sentiment_score', 'N/A')} | Advice: {summary.get('operation_advice', 'N/A')}")
        lines.append(f"Trend: {summary.get('trend_prediction', 'N/A')}")
        if strategy:
            lines.append(f"Buy: {strategy.get('ideal_buy', 'N/A')} | Stop: {strategy.get('stop_loss', 'N/A')}")
        lines.append(f"Summary: {summary.get('analysis_summary', 'N/A')[:200]}...")
    
    else:
        # Generic fallback
        lines.append(json.dumps(data, ensure_ascii=False, default=str)[:500])
    
    return "\n".join(lines)


