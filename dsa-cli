def main():
    """Main CLI entry point."""
    parser = argparse.ArgumentParser(
        prog="dsa-cli",
        description="Daily Stock Analysis CLI - A-share stock analysis tool for OpenClaw integration",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  dsa-cli analyze 600519          # Full AI analysis
  dsa-cli quote 600519            # Real-time quote
  dsa-cli trend 600519            # Technical trend
  dsa-cli news 600519             # Stock news
  dsa-cli batch 600519,000858     # Batch quotes
  dsa-cli quote 600519 --json     # JSON output
  dsa-cli analyze 600519 --brief  # Brief output

For OpenClaw integration:
  Use --json for structured output
  Use --brief for reduced token consumption
        """
    )
    
    parser.add_argument(
        "--json",
        action="store_true",
        help="Output as JSON (for OpenClaw parsing)"
    )
    
    parser.add_argument(
        "--brief",
        action="store_true",
        help="Brief output (reduced token consumption)"
    )
    
    parser.add_argument(
        "--days",
        type=int,
        default=60,
        help="Historical days for analysis (default: 60)"
    )
    
    parser.add_argument(
        "--debug",
        action="store_true",
        help="Enable debug logging"
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # analyze command
    analyze_parser = subparsers.add_parser("analyze", help="Full AI analysis")
    analyze_parser.add_argument("stock_code", help="Stock code (e.g., 600519)")
    analyze_parser.add_argument("--force-refresh", action="store_true", help="Force refresh data")
    analyze_parser.add_argument("--report-type", choices=["detailed", "brief"], default="detailed")
    analyze_parser.add_argument("--json", action="store_true", help="Output as JSON")
    analyze_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # quote command
    quote_parser = subparsers.add_parser("quote", help="Real-time quote")
    quote_parser.add_argument("stock_code", help="Stock code")
    quote_parser.add_argument("--json", action="store_true", help="Output as JSON")
    quote_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # trend command
    trend_parser = subparsers.add_parser("trend", help="Technical trend analysis")
    trend_parser.add_argument("stock_code", help="Stock code")
    trend_parser.add_argument("--json", action="store_true", help="Output as JSON")
    trend_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # news command
    news_parser = subparsers.add_parser("news", help="Search stock news")
    news_parser.add_argument("stock_code", help="Stock code")
    news_parser.add_argument("--days", type=int, default=7, help="News from last N days")
    news_parser.add_argument("--json", action="store_true", help="Output as JSON")
    news_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # ma command
    ma_parser = subparsers.add_parser("ma", help="Moving average analysis")
    ma_parser.add_argument("stock_code", help="Stock code")
    ma_parser.add_argument("--periods", help="MA periods (e.g., '5,10,20,60')")
    ma_parser.add_argument("--json", action="store_true", help="Output as JSON")
    ma_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # pattern command
    pattern_parser = subparsers.add_parser("pattern", help="K-line pattern recognition")
    pattern_parser.add_argument("stock_code", help="Stock code")
    pattern_parser.add_argument("--json", action="store_true", help="Output as JSON")
    pattern_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # volume command
    volume_parser = subparsers.add_parser("volume", help="Volume-price analysis")
    volume_parser.add_argument("stock_code", help="Stock code")
    volume_parser.add_argument("--json", action="store_true", help="Output as JSON")
    volume_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # levels command
    levels_parser = subparsers.add_parser("levels", help="Support/resistance levels")
    levels_parser.add_argument("stock_code", help="Stock code")
    levels_parser.add_argument("--json", action="store_true", help="Output as JSON")
    levels_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    # batch command
    batch_parser = subparsers.add_parser("batch", help="Batch analysis")
    batch_parser.add_argument("stock_codes", help="Comma-separated stock codes (e.g., 600519,000858)")
    batch_parser.add_argument("--json", action="store_true", help="Output as JSON")
    batch_parser.add_argument("--brief", action="store_true", help="Brief output")
    
    args = parser.parse_args()
    
    # Setup logging
    log_level = logging.DEBUG if args.debug else logging.WARNING
    setup_logging(console_level=log_level, log_prefix="dsa-cli")
    
    # No command specified
    if not args.command:
        parser.print_help()
        return 0
    
    # Register tools if needed
    from src.agent.tools.data_tools import ALL_DATA_TOOLS
    from src.agent.tools.search_tools import ALL_SEARCH_TOOLS
    from src.agent.tools.analysis_tools import ALL_ANALYSIS_TOOLS
    from src.agent.tools.registry import get_default_registry
    
    registry = get_default_registry()
    for tool in ALL_DATA_TOOLS + ALL_SEARCH_TOOLS + ALL_ANALYSIS_TOOLS:
        if tool.name not in registry:
            registry.register(tool)
    
    # Execute command
    result: Dict[str, Any] = {}
    
    if args.command == "analyze":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_analyze(stock_code, args)
    
    elif args.command == "quote":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_quote(stock_code, args)
    
    elif args.command == "trend":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_trend(stock_code, args)
    
    elif args.command == "news":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_news(stock_code, args)
    
    elif args.command == "ma":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_ma(stock_code, args)
    
    elif args.command == "pattern":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_pattern(stock_code, args)
    
    elif args.command == "volume":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_volume(stock_code, args)
    
    elif args.command == "levels":
        stock_code = canonical_stock_code(args.stock_code)
        result = cmd_levels(stock_code, args)
    
    elif args.command == "batch":
        codes = [canonical_stock_code(c.strip()) for c in args.stock_codes.split(",")]
        result = cmd_batch(codes, args)
    
    else:
        result = {"error": f"Unknown command: {args.command}"}
    
    # Format and print output
    # Check for --json or --brief from either global args or subcommand args
    use_json = getattr(args, 'json', False)
    use_brief = getattr(args, 'brief', False)
    
    if use_json:
        print(format_json(result))
    elif use_brief:
        print(format_brief(result, args.command))
    else:
        print(format_human(result, args.command))
    
    # Return exit code
    return 0 if "error" not in result else 1


if __name__ == "__main__":
    sys.exit(main())