def cmd_batch(stock_codes: List[str], args) -> Dict[str, Any]:
    """Run batch analysis on multiple stocks."""
    from src.agent.tools.registry import get_default_registry
    
    results = []
    errors = []
    
    try:
        registry = get_default_registry()
        
        for code in stock_codes:
            try:
                # Get quote for each stock
                quote = registry.execute("get_realtime_quote", stock_code=code)
                results.append({
                    "code": code,
                    "quote": quote if "error" not in quote else None,
                    "error": quote.get("error") if "error" in quote else None
                })
            except Exception as e:
                errors.append({"code": code, "error": str(e)})
        
        return {
            "total": len(stock_codes),
            "success": len(results) - len(errors),
            "errors": len(errors),
            "results": results,
        }
        
    except Exception as e:
        logger.error(f"Batch analysis failed: {e}", exc_info=True)
        return {"error": str(e)}


