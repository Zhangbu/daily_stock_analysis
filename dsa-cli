    if "error" in data:
        return f"❌ Error: {data['error']}"
    
    lines = []
    lines.append("=" * 50)
    
    if command == "quote":
        lines.append(f"📊 {data.get('name', 'N/A')} ({data.get('code', 'N/A')})")
        lines.append("=" * 50)
        lines.append(f"  Current Price:  {data.get('price', 'N/A')}")
        lines.append(f"  Change:         {data.get('change_pct', 'N/A')}%")
        lines.append(f"  Open:           {data.get('open', 'N/A')}")
        lines.append(f"  High:           {data.get('high', 'N/A')}")
        lines.append(f"  Low:            {data.get('low', 'N/A')}")
        lines.append(f"  Volume:         {data.get('volume', 'N/A')}")
        lines.append(f"  Turnover Rate:  {data.get('turnover_rate', 'N/A')}%")
    
    elif command == "trend":
        lines.append(f"📈 Technical Trend Analysis: {data.get('code', 'N/A')}")
        lines.append("=" * 50)
        lines.append(f"  Trend Status:   {data.get('trend_status', 'N/A')}")
        lines.append(f"  MA Alignment:   {data.get('ma_alignment', 'N/A')}")
        lines.append(f"  Trend Strength: {data.get('trend_strength', 'N/A')}")
        lines.append("")
        lines.append("  Moving Averages:")
        lines.append(f"    MA5:  {data.get('ma5', 'N/A')} (Bias: {data.get('bias_ma5', 'N/A')}%)")
        lines.append(f"    MA10: {data.get('ma10', 'N/A')} (Bias: {data.get('bias_ma10', 'N/A')}%)")
        lines.append(f"    MA20: {data.get('ma20', 'N/A')} (Bias: {data.get('bias_ma20', 'N/A')}%)")
        lines.append("")
        lines.append("  MACD:")
        lines.append(f"    DIF: {data.get('macd_dif', 'N/A')} | DEA: {data.get('macd_dea', 'N/A')}")
        lines.append(f"    Status: {data.get('macd_status', 'N/A')} - {data.get('macd_signal', 'N/A')}")
        lines.append("")
        lines.append("  RSI:")
        lines.append(f"    RSI6: {data.get('rsi_6', 'N/A')} | RSI12: {data.get('rsi_12', 'N/A')}")
        lines.append(f"    Status: {data.get('rsi_status', 'N/A')} - {data.get('rsi_signal', 'N/A')}")
        lines.append("")
        lines.append(f"  🎯 Signal: {data.get('buy_signal', 'N/A')} (Score: {data.get('signal_score', 'N/A')})")
        if data.get("signal_reasons"):
            lines.append("  Reasons:")
            for reason in data.get("signal_reasons", []):
                lines.append(f"    • {reason}")
    
    elif command == "analyze":
        report = data.get("report", {})
        meta = report.get("meta", {})
        summary = report.get("summary", {})
        strategy = report.get("strategy", {})
        
        lines.append(f"🔍 AI Analysis Report")
        lines.append("=" * 50)
        lines.append(f"  Stock: {meta.get('stock_name', 'N/A')} ({meta.get('stock_code', 'N/A')})")
        lines.append(f"  Price: {meta.get('current_price', 'N/A')} | Change: {meta.get('change_pct', 'N/A')}%")
        lines.append("")
        lines.append("  📊 Summary:")
        lines.append(f"    Score:    {summary.get('sentiment_score', 'N/A')}")
        lines.append(f"    Advice:   {summary.get('operation_advice', 'N/A')}")
        lines.append(f"    Trend:    {summary.get('trend_prediction', 'N/A')}")
        lines.append("")
        if strategy:
            lines.append("  📋 Strategy:")
            lines.append(f"    Ideal Buy:    {strategy.get('ideal_buy', 'N/A')}")
            lines.append(f"    Secondary Buy: {strategy.get('secondary_buy', 'N/A')}")
            lines.append(f"    Stop Loss:    {strategy.get('stop_loss', 'N/A')}")
            lines.append(f"    Take Profit:  {strategy.get('take_profit', 'N/A')}")
            lines.append("")
        
        analysis_summary = summary.get('analysis_summary', '')
        if analysis_summary:
            lines.append("  📝 Analysis:")
            for line in analysis_summary.split('\n')[:10]:
                lines.append(f"    {line}")
    
    else:
        # Generic fallback with JSON
        lines.append(f"Command: {command}")
        lines.append(json.dumps(data, ensure_ascii=False, indent=2, default=str))
    
    return "\n".join(lines)


