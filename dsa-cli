def cmd_analyze(stock_code: str, args) -> Dict[str, Any]:
    """Run full AI analysis on a stock."""
    import uuid
    from src.services.analysis_service import AnalysisService
    
    try:
        query_id = uuid.uuid4().hex
        service = AnalysisService()
        result = service.analyze_stock(
            stock_code=stock_code,
            report_type=getattr(args, 'report_type', 'detailed'),
            force_refresh=getattr(args, 'force_refresh', False),
            query_id=query_id
        )
        
        if result is None:
            return {"error": f"Failed to analyze stock {stock_code}"}
        
        return result
        
    except Exception as e:
        logger.error(f"Analysis failed: {e}", exc_info=True)
        return {"error": str(e)}


def cmd_quote(stock_code: str, args) -> Dict[str, Any]:
    """Get real-time stock quote."""
    from data_provider import DataFetcherManager
    
    try:
        manager = DataFetcherManager()
        quote = manager.get_realtime_quote(stock_code)
        
        if quote is None:
            return {"error": f"No quote data for {stock_code}"}
        
        return {
            "code": quote.code,
            "name": quote.name,
            "price": quote.price,
            "open": quote.open_price,  # open_price in UnifiedRealtimeQuote
            "high": quote.high,
            "low": quote.low,
            "volume": quote.volume,
            "amount": quote.amount,
            "change_pct": quote.change_pct,
            "turnover_rate": getattr(quote, 'turnover_rate', None),
            "pre_close": getattr(quote, 'pre_close', None),
        }
        
    except Exception as e:
        logger.error(f"Quote failed: {e}", exc_info=True)
        return {"error": str(e)}


