# ===================================
# A 股自选股智能分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# ===================================
# 1. 股票池配置
# ===================================
# A 股股票池（逗号分隔，支持沪深两市代码）
# 沪市：600xxx, 601xxx, 603xxx
# 深市：000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# 港股股票池（逗号分隔，可选）
# HK_STOCK_LIST=hk00700,HK09988

# 美股股票池（逗号分隔，可选）
# US_STOCK_LIST=AAPL,MSFT,NVDA,TSLA,AMD

# ===================================
# 2. AI 模型配置（多选一，至少配置一个）
# 系统调用顺序：Gemini > Anthropic > OpenAI 兼容（含 AIHubmix）
# ===================================

# 【方案一】使用 Gemini（推荐，有免费额度）
# 从 https://aistudio.google.com/ 获取免费 API Key
# 留空或删除此行则跳过 Gemini，直接使用其他方案
GEMINI_API_KEY=
# Optional: multiple keys for automatic failover (comma-separated)
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
# 温度参数（0.0-2.0）：控制输出随机性
GEMINI_TEMPERATURE=0.7
# 请求间隔（秒），防限流（优化点 7：从 2.0 降至 1.0）
GEMINI_REQUEST_DELAY=1.0
# 最大重试次数
GEMINI_MAX_RETRIES=5
# 重试基础延时（秒）
GEMINI_RETRY_DELAY=5.0
# 每个模型每分钟最大请求数（免费层建议 5）
GEMINI_PER_MODEL_RPM=5
# 每个模型每天最大请求数（免费层建议 20）
GEMINI_PER_MODEL_DAILY_LIMIT=20

# 【方案二】使用 Anthropic Claude API
# 从 https://console.anthropic.com 获取 API Key
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=8192

# 【方案三】使用 OpenAI 兼容 API（支持 AIHubmix/DeepSeek/通义千问等）
# AIHubmix（推荐）：https://aihubmix.com/?aff=CfMq
# 获取 Key 后取消下方注释即可使用
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# OPENAI_VISION_MODEL=  # 图像识别专用模型（可选，不填则用 OPENAI_MODEL）
# OPENAI_TEMPERATURE=0.7
# LLM_RESPONSE_STYLE=normal  # normal/caveman_lite/caveman_full/caveman_ultra

# 【方案四】使用 LiteLLM Proxy（高级，统一多模型）
# 前置：先启动 LiteLLM Proxy：litellm --config litellm_config.yaml
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=sk-litellm-proxy-local
# OPENAI_MODEL=gemini/gemini-3-pro-preview

# ===================================
# 3. 搜索引擎配置（用于获取股票新闻）
# ===================================
# Tavily API Keys（支持多个，逗号分隔）
TAVILY_API_KEYS=your_tavily_key_here
# SerpAPI Keys（支持多个，逗号分隔）
SERPAPI_API_KEYS=your_serpapi_key_here
# Brave Search API Keys（支持多个，逗号分隔）
# 获取：https://brave.com/search/api/
BRAVE_API_KEYS=your_brave_key_here

# ===================================
# 4. 通知渠道配置
# ===================================

# 【方式一】Telegram 机器人（需同时配置）
# 1. 在 Telegram 找 @BotFather -> /newbot -> 获取 Bot Token
# 2. 获取 Chat ID：发消息给 @userinfobot 或访问 https://api.telegram.org/bot<token>/getUpdates
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780  # Topic ID（群组话题，可选）
# TELEGRAM_VERIFY_SSL=true
# TELEGRAM_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# 【方式二】邮件推送（只需 2 项配置，SMTP 自动识别）
# 支持 QQ 邮箱、163 邮箱、Gmail、Outlook 等主流邮箱
# 1. 获取授权码（以 QQ 邮箱为例）：设置 -> 账户 -> POP3/SMTP 服务 -> 开启 -> 获取授权码
# EMAIL_SENDER=your_email@qq.com
# EMAIL_PASSWORD=your_email_auth_code
# EMAIL_RECEIVERS=receiver@example.com  # 可选，留空则发给自己

# 股票分组发往不同邮箱（Issue #268，可选）
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com

# 【方式三】Discord 配置
# Webhook 方式（推荐，配置简单）
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# Bot API 方式（需要 Bot 账号和频道 ID）
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_MAIN_CHANNEL_ID=your_channel_id_here

# 【精简模式说明】
# 企业微信/飞书/Pushover/PushPlus/Server酱/自定义 Webhook/AstrBot 在精简模式下不会启用。
# 需安装 wkhtmltopdf（Docker 已内置），本地运行：apt install wkhtmltopdf 或 brew install wkhtmltopdf
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,email,discord
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000

# ===================================
# 5. 推送行为配置
# ===================================
# 单股推送模式：每分析完一只股票立即推送，而不是汇总后推送
# SINGLE_STOCK_NOTIFY=false
# 报告类型：simple(精简) 或 full(完整)
# REPORT_TYPE=simple
# 仅分析结果摘要：设为 true 时只推送汇总，不含个股详情
# REPORT_SUMMARY_ONLY=false
# 个股分析与大盘复盘合并推送（默认 false）
# MERGE_EMAIL_NOTIFICATION=false
# 个股分析和大盘分析之间的延迟时间（秒），用于避免触发 API 限流
# ANALYSIS_DELAY=0

# ===================================
# 6. 定时任务配置
# ===================================
# 是否启用定时任务（true/false）
SCHEDULE_ENABLED=false
# 每日执行时间（HH:MM 格式，24 小时制）
SCHEDULE_TIME=18:00
# 间隔触发（分钟）。>0 时优先于 SCHEDULE_TIME（例如 30 表示每 30 分钟执行一次）
SCHEDULE_INTERVAL_MINUTES=0
# 启动时是否立即执行一次分析（true/false）
SCHEDULE_RUN_IMMEDIATELY=true
# 交易日检查：默认 true，非交易日跳过执行
# TRADING_DAY_CHECK_ENABLED=true
# 是否启用大盘复盘（true/false）
MARKET_REVIEW_ENABLED=true
# 大盘复盘市场区域：cn(A 股)、us(美股)、both(两者)
# MARKET_REVIEW_REGION=cn

# ===================================
# 7. 数据库配置
# ===================================
DATABASE_PATH=./data/stock_analysis.db

# ===================================
# 8. 回测配置
# ===================================
# 是否启用回测（true/false）
BACKTEST_ENABLED=true
# 回测评估窗口（交易日数）
BACKTEST_EVAL_WINDOW_DAYS=10
# 仅回测 N 天前的分析记录（避免数据不完整）
BACKTEST_MIN_AGE_DAYS=14
# 回测引擎版本
BACKTEST_ENGINE_VERSION=v1
# 中性区间阈值（%），例如 2 表示 -2%~+2% 视为震荡
BACKTEST_NEUTRAL_BAND_PCT=2.0

# ===================================
# 9. 系统配置
# ===================================
# 日志目录
LOG_DIR=./logs
# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# 最大并发线程数（优化点 7：从 3 提升至 5）
MAX_WORKERS=5
# 是否启用调试日志
DEBUG=false
# 代理配置（可选）
USE_PROXY=false
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10809

# ===================================
# 10. WebUI 配置
# ===================================
# 是否默认启动 WebUI（true/false，默认 false）
WEBUI_ENABLED=false
# WebUI 监听地址（Docker/Compose 场景需要 0.0.0.0）
WEBUI_HOST=127.0.0.1
# WebUI 监听端口（默认 8000）
WEBUI_PORT=8000
# 启动 Web 服务前是否自动构建前端（默认 true）
WEBUI_AUTO_BUILD=true
# 反向代理下信任 X-Forwarded-For 获取真实 IP
# TRUST_X_FORWARDED_FOR=false

# ===================================
# 11. Web 登录认证（可选）
# ===================================
# 设为 true 启用密码保护；首次访问时在网页设置初始密码
# 忘记密码可在服务器执行：python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24

# ===================================
# 12. 数据源优先级配置
# ===================================

# 历史数据源优先级（数字越小优先级越高）
# 默认：efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# EFINANCE_PRIORITY=0
# AKSHARE_PRIORITY=1
# TUSHARE_PRIORITY=2
# PYTDX_PRIORITY=2
# BAOSTOCK_PRIORITY=3
# YFINANCE_PRIORITY=4

# Pytdx 自定义服务器（内网/私有部署场景）
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# PYTDX_SERVERS=ip1:port1,ip2:port2

# 实时行情数据源优先级（逗号分隔，按顺序尝试）
# 支持：tencent, akshare_sina, efinance, akshare_em, tushare, yfinance
# 默认：tencent > akshare_sina > efinance > akshare_em
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
# 是否启用实时行情（关闭后使用历史收盘价分析）
# ENABLE_REALTIME_QUOTE=true
# 盘中实时技术面：启用时用实时价计算 MA/多头排列
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true
# 实时行情缓存 TTL（秒）
# REALTIME_CACHE_TTL=600
# 历史行情文件缓存 TTL（秒），0 表示仅按交易日新鲜度判断
# MARKET_DATA_CACHE_TTL=21600

# ===================================
# 13. 市场同步配置
# ===================================
# 市场日线同步开关：用于启动后后台增量拉取全市场/自选股历史数据
# MARKET_SYNC_ENABLED=false
# MARKET_SYNC_ON_STARTUP=false
# 同步市场，支持 cn,hk,us，逗号分隔
# MARKET_SYNC_MARKETS=cn,hk,us
# 是否启用 A 股全市场慢同步（false 时只同步自选股/配置池）
# MARKET_SYNC_A_SHARE_FULL_ENABLED=false
# 近一年历史回补天数
# MARKET_SYNC_HISTORICAL_DAYS=365
# 有历史时每次增量补最近几天
# MARKET_SYNC_INCREMENTAL_DAYS=5
# 单只股票之间休眠秒数，降低被封风险
# MARKET_SYNC_SLEEP_SECONDS=2.0
# 单次运行最多同步多少只股票，0 表示不限
# MARKET_SYNC_MAX_CODES_PER_RUN=0

# 市场同步前筛选配置（优化点 2：同步前筛选股票，减少同步数量）
# 启用同步前筛选（默认 true）
# MARKET_SYNC_FILTER_ENABLED=true
# 目标同步数量（默认 300）
# MARKET_SYNC_TARGET_COUNT=300
# 最小市值 50 亿（默认 5000000000）
# MARKET_SYNC_MIN_MARKET_CAP=5000000000
# 最小成交额 1 亿（默认 100000000）
# MARKET_SYNC_MIN_TURNOVER=100000000
# 最小换手率 1%（默认 1.0）
# MARKET_SYNC_MIN_TURNOVER_RATE=1.0
# 最大换手率 25%（默认 25.0）
# MARKET_SYNC_MAX_TURNOVER_RATE=25.0
# 最低股价 3 元（默认 3.0）
# MARKET_SYNC_MIN_PRICE=3.0
# 排除的股票代码前缀（默认 688,300 - 科创板/创业板）
# MARKET_SYNC_EXCLUDE_PREFIXES=688,300
# 跳过已同步到最新交易日的股票（默认 true）
# MARKET_SYNC_SKIP_FRESH=true

# 智能选股配置（优化点 2 扩展：从同步数据中选取股票参与分析）
# 启用智能选股（默认 false）
# MARKET_SYNC_STOCK_SELECTION_ENABLED=false
# 从同步数据中选取的股票数量（默认 10）
# MARKET_SYNC_SELECT_COUNT=10
# 选股策略（可选：best_performer, volume_surge, ma_golden_cross, bottom_volume, all_strategies）
# MARKET_SYNC_SELECTION_STRATEGY=best_performer

# ===================================
# 14. LLM 响应缓存配置（优化点 6：减少重复 API 调用）
# ===================================
# 启用 LLM 响应缓存（默认 true）
# LLM_CACHE_ENABLED=true
# 缓存有效期（小时，默认 24）
# LLM_CACHE_TTL_HOURS=24
# 最大缓存条目数（默认 1000）
# LLM_CACHE_MAX_SIZE=1000

# ===================================
# 15. 新闻与分析筛选配置
# ===================================
# 新闻最大时效（天），搜索时限制结果在近期内
# NEWS_MAX_AGE_DAYS=3
# 乖离率阈值（%），偏离 MA5 超过此值提示不追高
# BIAS_THRESHOLD=5.0
# 分析允许的数据最大滞后天数（超过后自动降级为"观望"）
# ANALYSIS_STALE_DAYS_LIMIT=2

# ===================================
# 16. Agent 策略对话配置（Web 对话页）
# ===================================
# 启用 Agent 对话（默认 false）
# AGENT_MODE=true
# Agent 最多推理步数
# AGENT_MAX_STEPS=10
# 默认启用策略（逗号分隔）
# 内置策略：bull_trend, ma_golden_cross, volume_breakout, shrink_pullback,
#           bottom_volume, dragon_head, one_yang_three_yin, box_oscillation,
#           chan_theory, wave_theory, emotion_cycle
# 推荐：趋势 + 金叉 + 缩量回踩
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
# 自定义策略目录（可选）
# AGENT_STRATEGY_DIR=./strategies

# ===================================
# 17. 可选模块 API 开关（Phase 2 模块化）
# ===================================
# ENABLE_AGENT_API=true
# ENABLE_BACKTEST_API=true
# ENABLE_STRATEGY_BACKTEST_API=true
# ENABLE_MARKET_SYNC_API=true
# ENABLE_SCREENING_API=true

# ===================================
# 18. 热门股与龙虎榜配置
# ===================================
# 热门股数量：涨幅榜前 N 只股票（默认 20）
# HOT_STOCKS_COUNT=20
# 龙虎榜天数：最近 N 天的龙虎榜数据（默认 1）
# LHB_DAYS=1
# 是否将龙虎榜股票纳入个股分析（默认 false）
# LHB_STOCKS_ANALYSIS_ENABLED=false
# 龙虎榜股票分析数量上限（默认 10）
# LHB_ANALYSIS_MAX_COUNT=10
# 龙虎榜股票最小净买入额（万元，默认 0）
# LHB_MIN_NET_BUY=0

# ===================================
# 19. 技术分析配置
# ===================================
# 历史数据天数（默认 30）
# HISTORICAL_DATA_DAYS=30
# 趋势分析窗口（天）
# TREND_ANALYSIS_WINDOW=60
# 最大历史数据天数
# MAX_HISTORICAL_DAYS=365

# ===================================
# 20. 其他配置
# ===================================
# 网页正文提取内存缓存 TTL（秒）
# ARTICLE_CONTENT_CACHE_TTL=1800
# 关键链路慢请求观测阈值（毫秒）
# OBSERVABILITY_WARN_LATENCY_MS=2000
# 熔断器冷却时间（秒）
# CIRCUIT_BREAKER_COOLDOWN=300
# 是否启用筹码分布（该接口不稳定，云端部署建议关闭）
# ENABLE_CHIP_DISTRIBUTION=true
# 是否启用东财请求接口补丁
# ENABLE_EASTMONEY_PATCH=false
# 是否启用资金流向分析
# ENABLE_FUND_FLOW=true
# 是否启用龙虎榜分析
# ENABLE_DRAGON_TIGER=true
# 是否启用板块轮动分析
# ENABLE_SECTOR_ROTATION=true
